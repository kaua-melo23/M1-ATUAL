# Este arquivo é gerado AUTOMATICAMENTE por run.py na inicialização.
# NÃO edite manualmente — altere as variáveis no .env:
#   TUNNEL_NAME, DOMAIN, HOST, PORT
#
# Para criar o tunnel pela primeira vez:
#   cloudflared tunnel login
#   cloudflared tunnel create <TUNNEL_NAME>
#   cloudflared tunnel route dns <TUNNEL_NAME> <DOMAIN>

tunnel: meu-tunnel
credentials-file: ~/.cloudflared/meu-tunnel.json

ingress:
  - hostname: cardapio.meudominio.com.br
    service: http://127.0.0.1:5000
  - service: http_status:404
